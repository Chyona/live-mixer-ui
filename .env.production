# 生产构建专用（pnpm build / mode=production）
# 勿写 VITE_API_PROXY_TARGET（生产不走 Vite 开发代理）
# 敏感覆盖可用本机 .env.production.local（已 gitignore）

VITE_APP_TITLE=简创AI剪辑平台
VITE_APP_DESCRIPTION=面向直播内容的 AI 智能切片与剪辑管理平台
VITE_SITE_URL=https://video-aigc.wxbpdapp.com
VITE_COMPANY_NAME=逗赛科技

VITE_NAV_LAYOUT=left
VITE_API_PREFIX=/openapi/live-mixer
VITE_LOGIN_MODE=page

VITE_GTM_ID=
VITE_ENABLE_GTM=true
VITE_ENABLE_FLOAT=false

# 生产禁止 Mock
VITE_MOCK=false
