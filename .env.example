# ========== 环境文件说明 ==========
# .env.example              仓库模板 → 复制为 .env
# .env                      本地开发默认（gitignore）
# .env.development.local    本地联调覆盖（gitignore，仅 pnpm dev）
# .env.production           生产打包（pnpm build）
# =================================

# 应用基础信息
VITE_APP_TITLE=简创AI剪辑平台
VITE_APP_DESCRIPTION=基于 React + Vite + Ant Design 的前端项目模板
VITE_SITE_URL=http://localhost:8008
VITE_COMPANY_NAME=逗赛科技

# 导航布局：top 顶部导航 | left 左侧导航
VITE_NAV_LAYOUT=left

# API 代理目标（仅开发环境 vite proxy，勿指向生产）
VITE_API_PREFIX=/openapi/live-mixer
VITE_API_PROXY_TARGET=http://127.0.0.1:30008

# 登录方式：page 独立页 /login | modal 弹窗（挂载在 MainLayout）
VITE_LOGIN_MODE=page

# Google Tag Manager（留空则不启用）
VITE_GTM_ID=
VITE_ENABLE_GTM=true

# 是否显示右下角悬浮客服入口
VITE_ENABLE_FLOAT=true

# 客服二维码图片 URL（留空则不显示二维码，仅展示文案）
# VITE_CONTACT_QRCODE_URL=
# VITE_SUPPORT_TITLE=Base UI 技术支持

# Mock 数据（本地无后端时建议开启；也可用 pnpm dev:mock）
VITE_MOCK=true

# 生产构建默认不生成 sourcemap；需要排查线上问题时设为 true
# GENERATE_SOURCEMAP=true

# 联调远程：新建 .env.development.local，例如：
#   VITE_API_PROXY_TARGET=http://192.168.3.219:30008
#   VITE_MOCK=false
